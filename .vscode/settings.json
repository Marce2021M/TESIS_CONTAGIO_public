{
  "latex-workshop.latex.recipe.default": "xelatex (minted)",

  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex-shell-escape",
      "command": "pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-shell-escape",
        "%DOC%"
      ]
    },
    {
      "name": "xelatex-shell-escape",
      "command": "xelatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-shell-escape",
        "%DOC%"
      ]
    },
    {
      "name": "biber",
      "command": "biber",
      "args": [
        "%DOCFILE%"
      ]
    }
  ],

  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex (minted)",
      "tools": [
        "pdflatex-shell-escape",
        "biber",
        "pdflatex-shell-escape",
        "pdflatex-shell-escape"
      ]
    },
    {
      "name": "xelatex (minted)",
      "tools": [
        "xelatex-shell-escape",
        "biber",
        "xelatex-shell-escape",
        "xelatex-shell-escape"
      ]
    }
  ]
}